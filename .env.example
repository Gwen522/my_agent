# ===== 模型配置 =====
# 模型提供商：第一期只支持 ollama
MODEL_PROVIDER=ollama

# Ollama 配置
OLLAMA_MODEL=qwen3:8b
MODEL_OPTIONS=qwen2.5:32b,qwen3.5:35b,deepseek-r1:70b
OLLAMA_BASE_URL=http://localhost:11434

# 通用参数（控制回答随机性，0=确定，1=创意）
MODEL_TEMPERATURE=0.7

# ===== 数据目录 =====
# USE_PROD_DATA=true  会使用 data/ 目录，否则使用 data_test/
